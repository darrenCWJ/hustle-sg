# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# AI
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo mode (INSECURE mock auth + /accounts credential list).
# Leave unset for the demo. Set to "false" for any real deployment — this
# disables mock-Singpass sign-in and the /accounts page, which require a real
# identity provider instead (see IMPROVEMENT_PLAN.md Phase 3.1).
NEXT_PUBLIC_DEMO_MODE=true

# Per-deployment salt for NRIC hashing (see SECURITY.md). Defaults to the
# public demo salt so seeded accounts work; set a unique secret on any
# staging/non-demo deployment.
NRIC_HASH_SALT=

# Web Push (VAPID) — optional; push is a no-op when unset
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com
